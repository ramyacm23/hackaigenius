# Copy this file to backend/.env and frontend/.env before running.
#
# --- backend/.env ---
APP_NAME=HackGenius AI
ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://app:app@db:5432/hackgenius
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
CORS_ORIGINS=http://localhost:3000

# --- frontend/.env ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
